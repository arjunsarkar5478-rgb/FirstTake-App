doctype html
html(lang="en")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    link(rel="stylesheet", href="/css/style.css")
    title FirstTake | Browse Talent
  body.landing-body
    header.landing-header.glass-card
      div.logo-container
        img(src="https://img.icons8.com/color/96/clapperboard.png" width="32" height="32")
        span.logo-text FirstTake
      nav.landing-nav
        a(href="/") Home
        a(href="/projects") Feed
        a(href="/talents" style="color: #38bdf8; font-weight: bold;") Browse Talent

    main(style="max-width: 1000px; margin: 40px auto; padding: 0 20px;")
      h1(style="text-align: center; margin-bottom: 40px; font-size: 2.5rem;") Browse Talent

      //- The CSS Grid for User Cards
      div(style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 25px;")
        if users && users.length > 0
          each user in users
            .glass-card(style="text-align: center; padding: 30px 20px; display: flex; flex-direction: column; align-items: center;")
              
              //- Avatar Circle
              div(style="width: 80px; height: 80px; border-radius: 50%; background: #0f172a; color: #38bdf8; display: flex; align-items: center; justify-content: center; font-size: 2rem; margin-bottom: 15px; border: 2px solid #38bdf8;")
                | #{user.name.charAt(0)}
              
              h2(style="margin: 0 0 5px 0; font-size: 1.5rem;") #{user.name}
              p(style="color: #38bdf8; font-size: 0.9rem; margin: 0 0 10px 0;") 📍 #{user.location}
              
              //- Bio (Limits to 3 lines so all cards stay the same height)
              p(style="font-size: 0.95rem; color: #cbd5e1; margin: 0 0 15px 0; line-height: 1.4; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; min-height: 60px;") 
                | #{user.role || 'Filmmaker and creative talent.'}
              
              //- Dummy Rating
              div(style="display: flex; justify-content: center; align-items: center; gap: 5px; margin-bottom: 20px; background: rgba(0,0,0,0.3); padding: 5px 12px; border-radius: 15px;")
                span(style="color: #facc15; font-size: 1rem;") ★★★★★
                span(style="color: #e2e8f0; font-size: 0.9rem; font-weight: bold;") 4.8
              
              //- View Profile Button (Pushes to the bottom)
              div(style="margin-top: auto; width: 100%;")
                a.btn-outline(href="/user/" + user.user_id style="display: block; width: 100%; box-sizing: border-box; text-align: center;") View Profile
        else
          p(style="text-align: center; grid-column: 1 / -1; color: #94a3b8; font-size: 1.2rem;") No talent found in the database yet.

    footer.glass-card.landing-footer(style="margin-top: 50px;")
      p FirstTake | GDPR Privacy Policy | Safe-Start Guidelines