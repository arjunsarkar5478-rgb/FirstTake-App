doctype html
html(lang="en")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    link(rel="stylesheet", href="/css/style.css")
    title FirstTake | Stop waiting. Start creating.
  body.landing-body
    //- Navigation Bar
    header.landing-header.glass-card
      div.logo-container
       div.logo-container
       div.logo-container
       div.logo-container
        //- Using a developer-friendly CDN that allows external image linking
        img(src="https://img.icons8.com/color/96/clapperboard.png" width="36" height="36" alt="FirstTake Logo" style="margin-right: 10px;")
        span.logo-text(style="font-size: 1.8rem;") FirstTake
      nav.landing-nav
        a(href="/projects") Feed
        a(href="#how-it-works") How it Works
        a(href="#login") Login
        a.btn-primary(href="#register") Register

    main
      //- Hero Section
      section.hero
        .hero-text
          h1 Stop waiting.<br>Start creating.
          p The safest networking platform for indie film creators. Pitch a script, cast your indie film, or find a scene partner to build your showreel.
          .button-group
            a.btn-primary(href="/create_project") POST PROJECT / SCRIPT
            a.btn-outline(href="/projects") FIND A ROLE
            a.btn-outline(href="/talents") FIND SCENE PARTNER
        .hero-visual
          //- External image link showing a film crew working on set
          img.glass-img(src="https://aaft.com/blog/wp-content/uploads/2024/09/pikaso_texttoimage_A-dynamic-scene-with-a-diverse-group-of-filmmakers-1024x701.jpeg", alt="Indie Film Crew on Set")
      //- How It Works Section
      section#how-it-works.features-section
        h2.section-title How FirstTake Connects You
        .grid-3
          //- Card 1: Create or Pitch (Updated with your custom Logo)
          .glass-card.feature-card(onclick="window.location.href='/create_project'")
            img(
              src="https://cdn.textstudio.com/output/sample/normal/3/7/1/5/create-logo-73-5173.png" 
              alt="Create Logo" 
              style="width: 120px; height: 120px; object-fit: contain; margin-bottom: 10px;"
            )
            h3 Create or Pitch
            p Directors post casting calls. Writers pitch scripts. Actors request scene partners.
            
          //- Card 2: Match & Collab (Team Hands Together Image)
          .glass-card.feature-card(onclick="window.location.href='/projects'")
            img(src="https://images.unsplash.com/photo-1521737604893-d14cc237f11d?auto=format&fit=crop&w=300&q=80" alt="Match and Collab" style="width: 80px; height: 80px; object-fit: cover; border-radius: 8px; margin-bottom: 15px;")
            h3 Match & Collab
            p Apply to roles, team up as Co-Admins, or link up to shoot showreel material.
            
          //- Card 3: Safe-Start Meeting (Coffee Shop Meeting Image)
          .glass-card.feature-card
            img(src="https://images.pexels.com/photos/3183150/pexels-photo-3183150.jpeg?auto=compress&cs=tinysrgb&w=300" alt="Safe Meeting" style="width: 80px; height: 80px; object-fit: cover; border-radius: 8px; margin-bottom: 15px;")
            h3 Safe-Start Meeting
            p Meet your new team in verified public Safe Zones before private contacts are revealed.
      //- Live Opportunities Preview Section
      section.opportunities-section
        .section-header
          h2.section-title Live Opportunities
          a.view-all(href="/projects") View all →
        .grid-3
          //- Card 1
          .glass-card.opp-card
            img.card-img(src="https://mymodernmet.com/wp/wp-content/uploads/2019/05/xavier-portela-hong-kong-glow-11.jpg", alt="Script Preview")
            .badges
              span.badge.badge-dark SCRIPT CALL
              span.badge.badge-light Sci-Fi
            h3 Neon Nights
            p.posted-by Posted by: Marcus (Writer)
            p.seeking Seeking: Director (Co-Admin)
            a.btn-outline.full-width(href="/project/3" style="display: block; text-align: center; box-sizing: border-box;") Read Pitch
            
          //- Card 2
          .glass-card.opp-card
            img.card-img(src="https://images.unsplash.com/photo-1623126908029-58cb08a2b272?auto=format&fit=crop&w=500&q=80", alt="Film Poster")
            .badges
              span.badge.badge-dark CASTING
              span.badge.badge-light Horror
            h3 Weekend Horror
            p.posted-by Posted by: Alex (Director)
            a.btn-outline.full-width(href="/project/1" style="display: block; text-align: center; box-sizing: border-box;") Apply Now
            
          //- Card 3
          .glass-card.opp-card
            img.card-img(src="https://images.unsplash.com/photo-1517630800677-932d836ab680?auto=format&fit=crop&w=500&q=80", alt="Headshot Reference")
            .badges
              span.badge.badge-dark ACTOR COLLAB
              span.badge.badge-light Drama
            h3 Cafe Argument Scene
            p.posted-by Posted by: Olivia (Actor)
            p.seeking Seeking: Scene Partner, Camera Op
            a.btn-outline.full-width(href="/project/2" style="display: block; text-align: center; box-sizing: border-box;") Connect

    //- Footer
    footer.glass-card.landing-footer
      span FirstTake
      span.footer-divider  |  
      button.footer-link(onclick="openPolicy('gdpr')") GDPR Privacy Policy
      span.footer-divider  |  
      button.footer-link(onclick="openPolicy('safestart')") Safe-Start Guidelines

    //- Policy Modal
    #policy-modal.policy-modal-overlay(onclick="closePolicy(event)")
      .policy-modal-box
        button.policy-close(onclick="document.getElementById('policy-modal').style.display='none'") ✕
        #policy-content

    script.
      const policies = {
        gdpr: {
          title: 'GDPR Privacy Policy',
          content: `
            <h3>Data Collection and Usage</h3>
            <p>FirstTake is committed to protecting personal privacy. The platform collects essential information, including names, contact details, profile images, and professional portfolios. This data is utilized strictly for the purpose of connecting talent with relevant casting opportunities and managing project applications.</p>
            <h3>Data Security</h3>
            <p>All personal information is encrypted and stored securely. Account details and application data are never sold to third parties or used for external marketing without explicit consent.</p>
            <h3>User Rights</h3>
            <p>Under the General Data Protection Regulation (GDPR), users retain full control over their data. Individuals have the right to:</p>
            <ul>
              <li>Access a copy of all personal data stored on the platform.</li>
              <li>Edit or update profile information at any time.</li>
              <li>Request the complete deletion of their account and associated data (Right to be Forgotten).</li>
            </ul>
            <p>To exercise any of these rights, or for questions regarding data management, please contact the platform's data protection officer.</p>
          `
        },
        safestart: {
          title: 'Safe-Start Guidelines',
          content: `
            <p>Safety is the highest priority for all physical and virtual auditions arranged through FirstTake. All participants are expected to adhere to the following safety protocols:</p>
            <h3>1. Public Venues for Initial Meetings</h3>
            <p>Always arrange first-time meetings in well-lit, public spaces such as coffee shops, rented studio spaces, or public libraries. Never agree to meet at a private residence for an initial introduction.</p>
            <h3>2. Verify Identities</h3>
            <p>Before attending an audition, research the production company or director. Request links to previous work, a professional website, or verify their identity through established industry networks.</p>
            <h3>3. Bring Accompaniment</h3>
            <p>Actors are highly encouraged to bring a trusted friend, family member, or talent representative to all first-time, in-person meetings.</p>
            <h3>4. Protect Personal Information</h3>
            <p>Do not provide banking details, home addresses, or social security numbers until an official, verified contract is offered.</p>
            <h3>5. Trust Instincts and Report</h3>
            <p>If a situation feels unsafe or unprofessional, leave immediately. Report any suspicious activity or fake projects directly to the platform administrators.</p>
          `
        }
      };

      function openPolicy(key) {
        const policy = policies[key];
        document.getElementById('policy-content').innerHTML = '<h2>' + policy.title + '</h2>' + policy.content;
        document.getElementById('policy-modal').style.display = 'flex';
      }

      function closePolicy(event) {
        if (event.target === document.getElementById('policy-modal')) {
          document.getElementById('policy-modal').style.display = 'none';
        }
      }