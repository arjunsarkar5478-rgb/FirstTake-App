extends layout

block content
  link(rel='stylesheet', href='/css/auth.css')
  
  .auth-wrapper
    div.auth-ambient-orb.auth-orb-cyan
    div.auth-ambient-orb.auth-orb-violet
    
    .auth-container.glass-card
      h1 Verify Your Account
      p(style="color: #94A3B8; text-align: center; margin-bottom: 30px;") We've sent a 6-digit code to your phone.
      
      form(action="/verify-otp" method="POST")
        div.auth-group
          label(for="otp") Enter 6-Digit Code:
          input(type="text" name="otp" maxlength="6" style="text-align: center; font-size: 24px; letter-spacing: 10px;" required)
          
        button.auth-btn(type="submit") VERIFY & CREATE ACCOUNT