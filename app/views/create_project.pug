doctype html
html(lang="en")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    link(rel="stylesheet", href="/css/style.css")
    title FirstTake | Create New Project
    style.
      .create-container { max-width: 800px; margin: 40px auto; width: 90%; }
      .top-bar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px; }
      .form-section { border: 1px solid rgba(255,255,255,0.1); border-radius: 8px; padding: 25px; margin-bottom: 30px; background: rgba(0,0,0,0.2); }
      .input-group { margin-bottom: 20px; width: 100%; box-sizing: border-box;}
      .input-label { display: block; margin-bottom: 8px; font-weight: bold; color: #cbd5e1; font-size: 0.95rem; }
      .flex-inputs { display: flex; gap: 20px; width: 100%; box-sizing: border-box;}
      .flex-item { flex: 1; box-sizing: border-box;}
      input, select, textarea { width: 100%; padding: 12px; border: 1px solid rgba(255,255,255,0.2); background: rgba(255,255,255,0.05); color: #e2e8f0; border-radius: 6px; font-size: 1rem; box-sizing: border-box;}
      input::placeholder, textarea::placeholder { color: #94a3b8; }
      textarea { resize: vertical; min-height: 120px; }
      .role-block { border: 1px dashed rgba(255,255,255,0.2); border-radius: 8px; padding: 20px; margin-bottom: 20px; position: relative; box-sizing: border-box;}
      .remove-role { position: absolute; top: 20px; right: 20px; color: #ef4444; text-decoration: underline; font-size: 0.85rem; cursor: pointer; }
      .add-role-dashed { border: 2px dashed rgba(255,255,255,0.1); border-radius: 8px; text-align: center; padding: 20px; color: #cbd5e1; font-weight: bold; cursor: pointer; margin-bottom: 40px; }
      .add-role-dashed:hover { background: rgba(255,255,255,0.02); }
      .action-buttons { display: flex; justify-content: space-between; gap: 20px; }
      .btn-draft { flex: 1; padding: 15px; background: none; border: 1px solid rgba(255,255,255,0.4); color: #e2e8f0; border-radius: 6px; font-size: 1rem; cursor: pointer; }
      .btn-publish { flex: 2; padding: 15px; background: #e2e8f0; color: #000; border: none; border-radius: 6px; font-size: 1.1rem; font-weight: bold; cursor: pointer; }
      
      /* Special styling for select dropdown since it's hard to style */
      select { appearance: none; -webkit-appearance: none; background-image: url('data:image/svg+xml;charset=US-ASCII,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20width%3D%22292.4%22%20height%3D%22292.4%22%3E%3Cpath%20fill%3D%22%23cbd5e1%22%20d%3D%22M287%2069.4a17.6%2017.6%200%200%200-13-5.4H18.4c-5%200-9.3%201.8-12.9%205.4A17.6%2017.6%200%200%200%200%2082.2c0%205%201.8%209.3%205.4%2012.9l128%20127.9c3.6%203.6%207.8%205.4%2012.8%205.4s9.2-1.8%2012.8-5.4L287%2095.1c3.6-3.6%205.4-7.8%205.4-12.9%200-5-1.8-9.3-5.4-12.9z%22%2F%3E%3C%2Fsvg%3E'); background-repeat: no-repeat, repeat; background-position: right 12px top 50%, 0 0; background-size: 10px auto, 100%;}
      select option { background-color: #000; color: #e2e8f0; }

  body.landing-body
    header.landing-header.glass-card
      div.logo-container
        img(src="https://img.icons8.com/color/96/clapperboard.png" width="32" height="32")
        span.logo-text FirstTake
      nav.landing-nav
        a(href="/") Home
        a(href="/projects") Feed
        a(href="/talents") Browse Talent

    main.create-container
      //- Top Navigation Bar (Matches wireframe)
      .top-bar
        a(href="/projects" style="color: #cbd5e1; text-decoration: underline;") ← Dashboard
        span(style="color: #cbd5e1; font-size: 0.9rem;") [FirstTake]

      //- Centered Title (Matches wireframe)
      h1(style="text-align: center; font-size: 2.2rem; margin-bottom: 40px; font-family: 'Montserrat', sans-serif;") Create New Project

      //- The main Form which connects exactly to image_7.png
      //- It submits a POST request to /publish-project
      form(action="/publish-project" method="POST")
        
        //- Project Title
        .input-group
          label.input-label(for="title") Project Title
          input#title(type="text" name="projectData[title]" placeholder="e.g., Weekend Horror Short" required)

        //- Genre & Location (Flex row matches wireframe)
        .flex-inputs
          .flex-item.input-group
            label.input-label(for="genre") Genre
            select#genre(name="projectData[genre]" required)
              option(value="" disabled selected) Select Genre...
              option(value="Horror") Horror
              option(value="Sci-Fi") Sci-Fi
              option(value="Drama") Drama
              option(value="Comedy") Comedy
              option(value="Showreel") Showreel
              option(value="Reel") Reel
          .flex-item.input-group
            label.input-label(for="location") Location
            //- THIS CONNECTS TO THE "LOCATION" COLUMN WE JUST ADDED TO THE DB
            input#location(type="text" name="projectData[location]" placeholder="e.g., London, UK" required)

        //- Project Description
        .input-group(style="margin-bottom: 30px;")
          label.input-label(for="description") Project Description
          textarea#description(name="projectData[description]" placeholder="Describe the plot, mutual benefits (e.g., food provided, footage for showreel), and dates..." required)

        //- Roles Required Section (Matches wireframe)
        h3(style="color: #e2e8f0; margin-bottom: 20px; font-weight: bold;") Roles Required

        //- The Dynamic container for roles (JS targets this)
        #rolesContainer

        //- The + Add Another Role dashed box (Matches wireframe)
        //- The onclick triggers the JS function below
        #addRoleBtn.add-role-dashed + Add Another Role

        //- Action Buttons (Matches wireframe exactly in style and order)
        .action-buttons
          button.btn-draft(type="button") Save Draft
          button.btn-publish(type="submit") PUBLISH PROJECT

    footer.glass-card.landing-footer(style="margin-top: 50px;")
      p FirstTake | GDPR Privacy Policy | Safe-Start Guidelines

    //- JavaScript to handle dynamic Roles (Matches wireframe behavior)
    script.
      const container = document.getElementById('rolesContainer');
      const addBtn = document.getElementById('addRoleBtn');
      let roleCount = 0;

      // Function to dynamically add a new role block exactly like the wireframe
      function addRole() {
        roleCount++;
        
        // Create the block container
        const roleBlock = document.createElement('div');
        roleBlock.className = 'role-block';
        roleBlock.id = `role-block-${roleCount}`;

        // Add the "Role #X" Title and "Remove" link from wireframe
        const headerFlex = document.createElement('div');
        headerFlex.className = 'flex-inputs';
        headerFlex.style.marginBottom = '20px';
        headerFlex.innerHTML = `
          <div class="flex-item"><label class="input-label">Role #${roleCount} Title</label></div>
          <div style="text-align: right;"><span class="remove-role" onclick="removeRole(${roleCount})">Remove</span></div>
        `;
        roleBlock.appendChild(headerFlex);

        // Add the inputs from the wireframe
        roleBlock.innerHTML += `
          <div class="input-group">
            <input type="text" name="projectData[roles][${roleCount-1}][title]" placeholder="e.g., Cinematographer" required>
          </div>
          <div class="input-group" style="margin-bottom: 0;">
            <label class="input-label">Role Requirements</label>
            <input type="text" name="projectData[roles][${roleCount-1}][requirements]" placeholder="e.g., Must have own RED camera setup" required>
          </div>
        `;

        container.appendChild(roleBlock);
      }

      // Function to remove a role block
      function removeRole(id) {
        const block = document.getElementById(`role-block-${id}`);
        block.remove();
        // Option to re-index, but complex. Simple MVP just removes.
      }

      // Add the first role by default on page load (matches wireframe starting state)
      addRole();

      // Connect the dashed box to the add function
      addBtn.addEventListener('click', addRole);