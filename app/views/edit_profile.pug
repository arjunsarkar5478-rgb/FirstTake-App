extends layout

block content
  link(rel='stylesheet', href='/profile.css')
  link(rel='stylesheet', href='/auth.css')

  .profile-wrapper
    div.auth-ambient-orb.auth-orb-cyan
    div.auth-ambient-orb.auth-orb-violet

    .profile-container
      .profile-nav
        a.back-link(href="/my-profile") &larr; Back to Profile

      h1.page-title Edit Profile
      
      .glass-card
        form(action="/edit-profile" method="POST" enctype="multipart/form-data")

          div.auth-group
            label(for="profile_picture") Upload Profile Picture:
            input(type="file" name="profile_picture" accept="image/*" style="color: #F8FAFC; margin-bottom: 15px;")

          //- THE FIX: Everything below here is now properly indented inside the form!
          div(style="margin-bottom: 15px;")
            label(for="phone_number" style="display: block; color: #38bdf8; margin-bottom: 5px;") Phone Number 
            input(type="tel" name="phone_number" id="phone_number" value=user.phone placeholder="+44 7584 549876" style="width: 100%; padding: 10px; background: rgba(0,0,0,0.5); color: white; border: 1px solid #334155; border-radius: 5px;")
          
          div.auth-group
            label(for="location") Location:
            input(type="text" name="location" value=user.location || '' placeholder="e.g., London, UK")
            
          div.auth-group
            label(for="bio") About Me:
            //- Using a textarea for a longer bio
            textarea(name="bio" rows="5" placeholder="Tell directors about yourself..." style="width: 100%; padding: 14px; background: rgba(11, 15, 25, 0.6); border: 1px solid rgba(255, 255, 255, 0.1); border-radius: 8px; color: #F8FAFC; font-family: 'Inter', sans-serif;")= user.bio || ''
            
          div.auth-group
            label(for="primary_link") Primary Portfolio/Social Link:
            input(type="text" name="primary_link" value=user.primary_link || '' placeholder="e.g., Instagram, TikTok, Website...")
            
          div.auth-group
            label(for="secondary_link") Secondary Link (Optional):
            input(type="text" name="secondary_link" value=user.secondary_link || '' placeholder="Another link...")
            
          button.auth-btn(type="submit" style="margin-top: 20px;") SAVE CHANGES

          
          