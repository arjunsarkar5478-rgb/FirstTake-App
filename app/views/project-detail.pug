doctype html
html(lang="en")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    link(rel="stylesheet", href="/css/style.css")
    title FirstTake | #{project.title}
  body.landing-body
    header.landing-header.glass-card
      div.logo-container
        img(src="https://img.icons8.com/color/96/clapperboard.png" width="32" height="32")
        span.logo-text FirstTake
      nav.landing-nav
        a(href="/") Home
        a(href="/projects") Feed
        a(href="/talents") Browse Talent
        a.btn-primary(href="/profile") My Profile

    main(style="max-width: 800px; margin: 0 auto; padding-top: 40px; padding-bottom: 80px;")
      //- Top Navigation
      div(style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;")
        a(href="/projects" style="color: #38BDF8; text-decoration: none; font-weight: 600;") ← Back to Feed
        span(style="color: #94A3B8; font-weight: bold;") [ FirstTake ]

      //- Centered Title
      section.section-header(style="text-align: center; margin-bottom: 30px;")
        h1(style="font-size: 2.5rem; margin-bottom: 10px; color: #F8FAFC;") #{project.title}
        hr(style="border: 0; border-top: 1px solid rgba(255,255,255,0.2); margin: 0 auto; width: 100%; max-width: 600px;")

      //- Main Info Box
      .glass-card.outline-box
        p.info-line
          strong Director: 
          span #{project.director || 'Anonymous'} 
          a(href=`/user/${project.owner_user_id}` style="color: #38BDF8; font-size: 0.9rem; text-decoration: underline;") (View Profile)
        p.info-line
          strong Genre: 
          span #{project.genre}
        p.info-line
          strong Location: 
          span London, UK
        p.info-line(style="margin-bottom: 25px;")
          strong Budget: 
          span No Budget (Mutual Benefit / Student Film)
        
        div
          strong(style="font-size: 1.1rem; display: block; margin-bottom: 5px;") Description:
          p(style="line-height: 1.6; color: #CBD5E1;") #{project.description}

      //- Roles Required Section
      h2(style="margin-bottom: 15px; margin-top: 40px; color: #F8FAFC; text-decoration: underline; text-underline-offset: 6px;") Roles Required
      
      .glass-card.outline-box(style="padding: 0;")
        if roles && roles.length > 0
          each role, index in roles
            div.role-item(style=index !== roles.length - 1 ? "border-bottom: 1px dashed rgba(255,255,255,0.2);" : "")
              div.role-text
                //- We print your exact database column here
                h3(style="font-size: 1.1rem; color: #F8FAFC; font-weight: normal;") #{role.requirement_text}
              div.role-button
                button.btn-outline.apply-btn APPLY NOW
        else
          div(style="padding: 30px; text-align: center; color: #94A3B8;") No specific roles listed yet.

    footer.glass-card.landing-footer
      p FirstTake | GDPR Privacy Policy | Safe-Start Guidelines