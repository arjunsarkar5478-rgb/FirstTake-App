extends layout

block content
  //- A "Back" link to return to the feed
  a(href="/projects" style="color: #F8FAFC; text-decoration: none;") ← Back to Feed
  
  .glass-card(style="margin-top: 20px;")
    h1= project.title
    p 
      strong Director: 
      | #{project.director}
    p 
      strong Description: 
      | #{project.description}
      
    h3 Roles Required (Max 5 Applicants per Role)
    hr(style="border-color: rgba(255,255,255,0.1); margin-bottom: 20px;")
    
    //- Loop through the specific roles for this project
    each role in project.roles
      div(style="background: rgba(0,0,0,0.2); padding: 15px; border-radius: 8px; margin-bottom: 15px;")
        h4(style="margin-top: 0;")= role.title
        p Requirements: #{role.requirements}
        p Applicants: (#{role.applicants}/5)
        
        //- SPRINT 2 ANTI-CRASH LOGIC
        if role.applicants >= 5
          button.btn-primary(disabled style="background-color: #475569; color: #94A3B8; cursor: not-allowed;") LIMIT REACHED
        else
          button.btn-primary APPLY NOW